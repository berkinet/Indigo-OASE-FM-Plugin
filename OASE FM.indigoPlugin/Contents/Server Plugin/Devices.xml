            </State>
            <State id="firmwareHigh" readonly="true">
                <ValueType>Number</ValueType>
                <TriggerLabel>Firmware high</TriggerLabel>
                <ControlPageLabel>Firmware high</ControlPageLabel>
            </State>
            <State id="wifiChannel" readonly="true">
                <ValueType>Number</ValueType>
                <TriggerLabel>Wi-Fi channel</TriggerLabel>
                <ControlPageLabel>Wi-Fi channel</ControlPageLabel>
            </State>
            <State id="networkType" readonly="true">
                <ValueType>Number</ValueType>
                <TriggerLabel>Network type</TriggerLabel>
                <ControlPageLabel>Network type</ControlPageLabel>
            </State>
            <State id="statusText" readonly="true">
                <ValueType>String</ValueType>
                <TriggerLabel>Status text</TriggerLabel>
                <ControlPageLabel>Status text</ControlPageLabel>
            </State>
        </States>
    </Device>
</Devices>
