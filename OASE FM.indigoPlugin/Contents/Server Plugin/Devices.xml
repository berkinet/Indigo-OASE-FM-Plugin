<?xml version="1.0"?>
<Devices>
    <Device type="relay" id="switchedSocket">
        <Name>Switched socket</Name>
        <ConfigUI>
            <Field id="socketNumber" type="menu">
                <Label>Socket:</Label>
                <List>
                    <Option value="1">1</Option>
                    <Option value="2">2</Option>
                    <Option value="4">4</Option>
                </List>
            </Field>
            <Field id="address" type="textfield" readonly="true">
                <Label>Address:</Label>
            </Field>
        </ConfigUI>
    </Device>
    <Device type="dimmer" id="dimmableSocket">
        <Name>Dimmable socket</Name>
        <ConfigUI>
            <Field id="physicalSocket" type="label">
                <Label>This device controls physical socket 3.</Label>
            </Field>
            <Field id="address" type="textfield" readonly="true">
                <Label>Address:</Label>
            </Field>
        </ConfigUI>
    </Device>
    <Device type="dimmer" id="egcDevice">
        <Name>EGC device</Name>
        <ConfigUI>
            <Field id="egcSelection" type="label">
                <Label>The single attached EGC device is selected automatically.</Label>
            </Field>
            <Field id="address" type="textfield" readonly="true">
                <Label>Address:</Label>
            </Field>
        </ConfigUI>
        <States>
            <State id="rpm" readonly="true">
                <ValueType>Number</ValueType>
                <TriggerLabel>RPM</TriggerLabel>
                <ControlPageLabel>RPM</ControlPageLabel>
            </State>
            <State id="watts" readonly="true">
                <ValueType>Number</ValueType>
                <TriggerLabel>Power consumption</TriggerLabel>
                <ControlPageLabel>Power consumption</ControlPageLabel>
            </State>
            <State id="moduleTemperature" readonly="true">
                <ValueType>Number</ValueType>
                <TriggerLabel>Module temperature</TriggerLabel>
                <ControlPageLabel>Module temperature</ControlPageLabel>
            </State>
            <State id="pcbTemperature" readonly="true">
                <ValueType>Number</ValueType>
                <TriggerLabel>PCB temperature</TriggerLabel>
                <ControlPageLabel>PCB temperature</ControlPageLabel>
            </State>
            <State id="waterTemperature" readonly="true">
                <ValueType>Number</ValueType>
                <TriggerLabel>Water temperature</TriggerLabel>
                <ControlPageLabel>Water temperature</ControlPageLabel>
            </State>
            <State id="sfcEnabled" readonly="true">
                <ValueType>Boolean</ValueType>
                <TriggerLabel>SFC enabled</TriggerLabel>
                <ControlPageLabel>SFC enabled</ControlPageLabel>
            </State>
            <State id="sfcMode" readonly="true">
                <ValueType>String</ValueType>
                <TriggerLabel>SFC mode</TriggerLabel>
                <ControlPageLabel>SFC mode</ControlPageLabel>
            </State>
            <State id="manufacturerIdentifier" readonly="true">
                <ValueType>Number</ValueType>
                <TriggerLabel>Manufacturer identifier</TriggerLabel>
                <ControlPageLabel>Manufacturer identifier</ControlPageLabel>
            </State>
            <State id="deviceIdentifier" readonly="true">
                <ValueType>Number</ValueType>
                <TriggerLabel>Device identifier</TriggerLabel>
                <ControlPageLabel>Device identifier</ControlPageLabel>
            </State>
            <State id="uid" readonly="true">
                <ValueType>String</ValueType>
                <TriggerLabel>Stable UID</TriggerLabel>
                <ControlPageLabel>Stable UID</ControlPageLabel>
            </State>
            <State id="articleNumber" readonly="true">
                <ValueType>Number</ValueType>
                <TriggerLabel>Article number</TriggerLabel>
                <ControlPageLabel>Article number</ControlPageLabel>
            </State>
            <State id="subdeviceCount" readonly="true">
                <ValueType>Number</ValueType>
                <TriggerLabel>Subdevice count</TriggerLabel>
                <ControlPageLabel>Subdevice count</ControlPageLabel>
            </State>
        </States>
    </Device>
    <Device type="sensor" id="controllerDevice">
        <Name>FM-Master controller</Name>
        <ConfigUI>
            <Field id="controllerSelection" type="label">
                <Label>This device represents the configured FM-Master controller.</Label>
            </Field>
            <Field id="address" type="textfield" readonly="true">
                <Label>Address:</Label>
            </Field>
        </ConfigUI>
        <States>
            <State id="connected" readonly="true">
                <ValueType>Boolean</ValueType>
                <TriggerLabel>Connected</TriggerLabel>
                <ControlPageLabel>Connected</ControlPageLabel>
            </State>
            <State id="authenticated" readonly="true">
                <ValueType>Boolean</ValueType>
                <TriggerLabel>Authenticated</TriggerLabel>
                <ControlPageLabel>Authenticated</ControlPageLabel>
