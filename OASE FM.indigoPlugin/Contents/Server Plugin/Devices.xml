                <ControlPageLabel>Controller name</ControlPageLabel>
            </State>
            <State id="serialNumber" readonly="true">
                <ValueType>String</ValueType>
                <TriggerLabel>Serial number</TriggerLabel>
                <ControlPageLabel>Serial number</ControlPageLabel>
            </State>
            <State id="modelName" readonly="true">
                <ValueType>String</ValueType>
                <TriggerLabel>Model name</TriggerLabel>
                <ControlPageLabel>Model name</ControlPageLabel>
            </State>
            <State id="articleNumber" readonly="true">
                <ValueType>Number</ValueType>
                <TriggerLabel>Order/article number</TriggerLabel>
                <ControlPageLabel>Order/article number</ControlPageLabel>
            </State>
            <State id="firmware" readonly="true">
                <ValueType>Number</ValueType>
                <TriggerLabel>Firmware</TriggerLabel>
                <ControlPageLabel>Firmware</ControlPageLabel>
            </State>
            <State id="firmwareLow" readonly="true">
